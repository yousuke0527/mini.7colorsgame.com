---
interface Props { lang?: string }
const path = Astro.url.pathname;
const lang = Astro.props.lang || (path === '/en/' || path.startsWith('/en/') ? 'en' : 'ja');
const isEn = lang === 'en';
const jaPath = path === '/en/' ? '/' : path.startsWith('/en/') ? path.slice(3) || '/' : path;
const enPath = path === '/' ? '/en/' : path.startsWith('/en/') ? path : path.startsWith('/play/') ? `/en${path}` : '/en/';
const home = isEn ? '/en/' : '/';
---

<header class="sticky top-0 z-50 border-b border-cyan-300/15 bg-[#020617]/85 shadow-[0_10px_35px_rgba(2,6,23,.5)] backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <a href={home} class="group flex min-w-0 items-center gap-3" aria-label="Mini Games home">
      <span class="relative grid h-10 w-10 shrink-0 place-items-center overflow-hidden rounded-[14px] border border-cyan-200/40 bg-gradient-to-br from-fuchsia-500 via-violet-600 to-cyan-500 shadow-[0_0_24px_rgba(34,211,238,.3)] transition group-hover:rotate-[-7deg] group-hover:scale-110">
        <svg viewBox="0 0 40 40" class="h-8 w-8" aria-hidden="true">
          <path d="M10 16c-3 1-5 5-5 10 0 4 2 7 5 7 3 0 5-4 7-6h6c2 2 4 6 7 6s5-3 5-7c0-5-2-9-5-10-5-2-15-2-20 0z" fill="#06142c" stroke="#fff" stroke-width="2"/>
          <path d="M13 20v7M9.5 23.5h7" stroke="#67e8f9" stroke-width="2.4" stroke-linecap="round"/>
          <circle cx="27" cy="22" r="2" fill="#f9a8d4"/><circle cx="31" cy="26" r="2" fill="#fde68a"/>
          <path d="M20 4l2.5 6 6 2.5-6 2.5-2.5 6-2.5-6-6-2.5 6-2.5z" fill="#fff" opacity=".9"/>
        </svg>
      </span>
      <span class="truncate text-lg font-black tracking-tight text-white sm:text-xl">Mini <span class="text-cyan-300">Games</span></span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label={isEn ? 'Main navigation' : 'メインメニュー'}>
      <a href={home} class="text-sm font-black text-white transition hover:text-cyan-300">{isEn ? 'Home' : 'ホーム'}</a>
      <a href={`${home}#ranking`} id="nav-ranking-btn" class="text-sm font-bold text-slate-400 transition hover:text-fuchsia-300">{isEn ? 'Ranking' : 'ランキング'}</a>
      <a href={`${home}#favorites`} id="nav-fav-btn" class="flex items-center gap-1.5 text-sm font-bold text-slate-400 transition hover:text-rose-300">
        <span aria-hidden="true" class="text-rose-400">♥</span>{isEn ? 'Favorites' : 'お気に入り'}
        <span id="header-fav-count" class="hidden min-w-5 rounded-full bg-rose-500/20 px-1.5 py-0.5 text-center text-[10px] text-rose-200">0</span>
      </a>
    </nav>

    <div class="flex shrink-0 items-center rounded-full border border-white/10 bg-slate-900/80 p-1 text-[11px] font-black" aria-label={isEn ? 'Language' : '言語'}>
      <a href={jaPath} lang="ja" hreflang="ja" class:list={['rounded-full px-2.5 py-1.5 transition sm:px-3', !isEn ? 'bg-white text-slate-950 shadow' : 'text-slate-400 hover:text-white']}>日本語</a>
      <a href={enPath} lang="en" hreflang="en" class:list={['rounded-full px-2.5 py-1.5 transition sm:px-3', isEn ? 'bg-cyan-300 text-slate-950 shadow' : 'text-slate-400 hover:text-white']}>EN</a>
    </div>
  </div>
</header>

<script>
  const updateHeaderFavoriteCount = () => {
    const badge = document.querySelector<HTMLElement>('#header-fav-count');
    if (!badge) return;
    try {
      const favorites = JSON.parse(localStorage.getItem('ag-favorites') || '[]') as string[];
      badge.textContent = String(favorites.length);
      badge.classList.toggle('hidden', favorites.length === 0);
    } catch {
      localStorage.removeItem('ag-favorites');
      badge.classList.add('hidden');
    }
  };
  updateHeaderFavoriteCount();
  window.addEventListener('ag:favorites-changed', updateHeaderFavoriteCount);
  window.addEventListener('storage', updateHeaderFavoriteCount);
</script>
