---
interface Props {
  slot?: string;
  className?: string;
}

const { slot = "1005373448", className = "" } = Astro.props;
---

<div class={`ads-container my-8 p-4 bg-slate-900/30 border border-slate-800/80 backdrop-blur-md rounded-2xl overflow-hidden flex flex-col items-center justify-center min-h-[140px] sm:min-h-[280px] w-full relative ${className}`}>
  <!-- CLS回避プレースホルダー骨組み -->
  <div class="absolute inset-0 bg-slate-950/20 rounded-2xl flex flex-col items-center justify-center select-none pointer-events-none border border-dashed border-slate-800/50 m-2">
    <span class="text-[9px] text-slate-600 uppercase tracking-widest font-extrabold mb-1">Advertisement</span>
    <span class="text-[10px] text-slate-700 font-semibold">Google AdSense Space</span>
  </div>
  
  <div class="w-full max-w-4xl min-h-[90px] sm:min-h-[250px] flex items-center justify-center relative z-10">
    <!-- Google AdSense -->
    <!-- ディスプレイ広告_レスポンシブ -->
    <ins class="adsbygoogle"
      style="display:block; width:100%; min-height:90px;"
      data-ad-client="ca-pub-8654623397015129"
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"
      aria-label="Advertisement"></ins>
    <script is:inline>
      (() => {
        const ad = document.currentScript?.previousElementSibling;
        if (!(ad instanceof HTMLElement)) return;

        const initializeAd = () => {
          if (ad.dataset.adsbygoogleStatus || ad.getBoundingClientRect().width <= 0) return;
          try {
            (window.adsbygoogle = window.adsbygoogle || []).push({});
          } catch (error) {
            console.warn('AdSense slot initialization was deferred.', error);
          }
        };

        requestAnimationFrame(initializeAd);
      })();
    </script>
  </div>
</div>
