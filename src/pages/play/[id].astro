const activeTranslation = gameTranslations[game.slug];
const translatedTitle = lang === 'en' ? (activeTranslation?.titleEn || title) : title;
const translatedDesc = lang === 'en' ? (activeTranslation?.descEn || description) : description;
const activeTitle = simpleGameTitle(translatedTitle, lang, game.slug);
const activeDesc = simpleGameDescription(game.slug, translatedDesc, lang);
const endlessClearTarget = getEndlessClearTarget(game.slug);

const tUi = {
  backToList: lang === 'en' ? "Back to Games List" : "ゲーム一覧に戻る",
  difficulty: lang === 'en' ? "Difficulty" : "難易度",
  restart: lang === 'en' ? "Restart" : "リスタート",
  restartTooltip: lang === 'en' ? "Restart the game" : "ゲームをリスタートします",
  fullscreen: lang === 'en' ? "Fullscreen" : "フルスクリーン",
  fullscreenTooltip: lang === 'en' ? "Toggle fullscreen mode" : "フルスクリーン表示に切り替えます",
  favorite: lang === 'en' ? "Favorite" : "お気に入り",
  favorited: lang === 'en' ? "Favorited" : "お気に入り済み",
  favoriteTooltip: lang === 'en' ? "Add this game to favorites" : "このゲームをお気に入りに追加します",
  clearTarget: lang === 'en' ? "Clear target" : "クリア条件",
  controls: lang === 'en' ? "Controls" : "操作方法",
  loading: lang === 'en' ? "Initializing System..." : "システム初期化中...",
  loadingControls: lang === 'en' ? "Loading controls..." : "操作方法を読み込み中..."
};

// ゲームごとのJSON-LDを動的に構築
const canonicalUrl = `https://mini.7colorsgame.com/play/${game.slug}/`;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Game",
      "@id": `${canonicalUrl}#game`,
      "name": activeTitle,
      "description": activeDesc,
      "genre": category,
      "playMode": "SinglePlayer",
      "applicationCategory": "Game",
      "operatingSystem": "Any"
    },
    {
      "@type": "HowTo",
      "@id": `${canonicalUrl}#howto`,
      "name": lang === 'en' ? `Play ${activeTitle} Online Free` : `【インストール不要】${title}の遊び方・操作手順`,
      "description": lang === 'en' ? `How to play ${activeTitle} online for free. Instructions and rules.` : `ブラウザで今すぐ無料で遊べる${title}の操作説明とルールです。`,
      "step": [
        {
          "@type": "HowToStep",
          "text": lang === 'en' ? "Click or tap on the game canvas to initialize and start." : "ゲーム画面をクリックまたはタップして初期化・スタートします。"
        },
        {
          "@type": "HowToStep",
          "text": lang === 'en' ? "Follow rules and steer controls to clear stages and reach high scores." : "操作方法やルールに沿ってプレイし、ハイスコアを目指します。"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": lang === 'en' ? `Can I play ${activeTitle} on mobile phones?` : `${title}はスマートフォンでもプレイ可能ですか？`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": lang === 'en' 
              ? "Yes, it is fully compatible with touchscreen swipe and tap controls on mobile smartphones and tablets with no install needed."
              : `はい、スマートフォンおよびタブレットのタッチ・スワイプ操作に完全対応しています。アプリのインストール不要で、Webブラウザ上で快適に動作します。`
          }
        },
        {
          "@type": "Question",
          "name": lang === 'en' ? "Is there any charge or account registration needed?" : "プレイ料金や登録は必要ですか？",
