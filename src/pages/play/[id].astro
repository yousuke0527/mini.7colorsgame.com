export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map(game => ({
    params: { id: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props;
const { title, description, category, difficulty } = game.data;

const lang = Astro.url.pathname.startsWith('/en/') || Astro.url.searchParams.get('lang') === 'en' ? 'en' : 'ja';

