          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 1 0 3-6.7L3 8" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v5h5" />
            </svg>
          </button>
          <button 
            id="btn-fullscreen" 
            class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-cyan-300/25 bg-slate-900/80 text-white shadow-md backdrop-blur-md transition hover:scale-105 hover:border-cyan-200 hover:bg-cyan-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300"
            title={tUi.fullscreenTooltip}
            aria-label={tUi.fullscreenTooltip}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 3H3v5M16 3h5v5M8 21H3v-5M16 21h5v-5" />
            </svg>
          </button>
        </div>
        <span class="text-xs font-bold px-3.5 py-1.5 rounded-full bg-slate-900/60 backdrop-blur-md text-brand-accent border border-brand-primary/20">
          {category}
        </span>
        <span class="text-xs font-bold px-3.5 py-1.5 rounded-full bg-slate-900/60 backdrop-blur-md text-slate-300 border border-slate-800/80">
          {tUi.difficulty}: {difficulty}
        </span>
      </div>
    </div>

    <!-- ゲーム画面を横幅いっぱいに表示 -->
    <div class="flex flex-col gap-5">
      <div class="flex flex-col gap-5">
        <div 
          id="game-container" 
          data-game-id={game.slug}
          data-lang={lang}
          data-clear-score={endlessClearTarget || undefined}
          data-controls-en={JSON.stringify(activeTranslation?.controlsEn || [])}
          class="relative w-full aspect-[4/3] sm:aspect-[16/10] rounded-2xl overflow-hidden shadow-2xl bg-slate-950/40 backdrop-blur-md border border-slate-800/80 p-0 flex items-center justify-center group/screen"
        >
          <!-- 背景ネオングローレイヤー -->
          <div class="absolute -inset-4 bg-gradient-to-tr from-brand-primary/10 to-brand-accent/10 opacity-30 blur-2xl pointer-events-none group-hover/screen:opacity-50 transition-opacity duration-700"></div>

          <!-- キャンバス -->
          <canvas 
            id="game-canvas" 
            class="hidden w-full h-full object-contain block focus:outline-none z-10"
            tabindex="0"
          ></canvas>

          <!-- ローディング・状態インジケータ -->
          <div id="game-loader" class="absolute inset-0 flex flex-col items-center justify-center bg-slate-950/85 backdrop-blur-sm z-20 transition-opacity duration-300">
            <div class="w-12 h-12 border-4 border-brand-accent border-t-transparent rounded-full animate-spin mb-4"></div>
            <p id="loader-text" class="text-sm font-bold text-slate-400">{tUi.loading}</p>
          </div>
        </div>
      </div>

      <!-- ゲーム画面下の説明・操作方法 -->
      <section class="group/panel relative overflow-hidden rounded-2xl border border-slate-800/80 bg-slate-900/40 p-5 shadow-lg backdrop-blur-md sm:p-6">
        <div class="absolute left-0 top-0 h-[2px] w-full bg-gradient-to-r from-brand-accent to-brand-primary"></div>
        <div class="grid gap-6 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.5fr)] lg:gap-10">
          <div>
            <h1 class="mb-3 text-2xl font-extrabold text-white transition-colors duration-300 group-hover/panel:text-brand-accent">{activeTitle}</h1>
            <p class="text-sm font-medium leading-relaxed text-slate-400">{activeDesc}</p>
            {endlessClearTarget > 0 && (
              <p class="mt-4 inline-flex items-center gap-2 rounded-full border border-emerald-300/25 bg-emerald-400/10 px-3 py-1.5 text-xs font-extrabold text-emerald-300">
                <span aria-hidden="true">✓</span>
                {tUi.clearTarget}: {endlessClearTarget.toLocaleString(lang === 'en' ? 'en-US' : 'ja-JP')} {lang === 'en' ? 'points' : '点以上'}
              </p>
            )}
          </div>
          <div class="border-t border-slate-800 pt-5 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0">
            <h2 class="mb-4 text-xs font-extrabold uppercase tracking-widest text-brand-accent select-none">{tUi.controls}</h2>
            <div id="game-controls-instructions" class="grid gap-3 text-sm leading-relaxed text-slate-400 sm:grid-cols-2">
              <p class="text-slate-500 italic">{tUi.loadingControls}</p>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Google AdSense 広告をスマートに埋め込み -->
    <AdSense className="mt-12" />
  </div>
</Layout>

<script>
  import { installCanvasTextI18n } from '../../lib/canvasTextI18n';

  async function initGameContainer() {
    const container = document.getElementById('game-container');
    const loader = document.getElementById('game-loader');
    const canvas = document.getElementById('game-canvas') as HTMLCanvasElement;
    const instructionBox = document.getElementById('game-controls-instructions');
    const btnFullscreen = document.getElementById('btn-fullscreen');
    const btnRestart = document.getElementById('btn-restart');
    const btnFavorite = document.getElementById('btn-favorite') as HTMLButtonElement | null;

    if (!container || !canvas) return;

    const gameId = container.dataset.gameId;
    const lang = container.dataset.lang || 'ja';
    const clearScore = Number(container.dataset.clearScore || 0);
    const controlsEnRaw = container.dataset.controlsEn;
    const controlsEn = controlsEnRaw ? JSON.parse(controlsEnRaw) : [];
    let gameInstance: any = null;

    const readFavorites = () => {
      try { return JSON.parse(localStorage.getItem('ag-favorites') || '[]') as string[]; }
      catch { localStorage.removeItem('ag-favorites'); return []; }
    };
    const paintFavorite = () => {
      if (!btnFavorite || !gameId) return;
      const selected = readFavorites().includes(gameId);
      btnFavorite.setAttribute('aria-pressed', String(selected));
      btnFavorite.classList.toggle('border-rose-300', selected);
      btnFavorite.classList.toggle('bg-rose-500/20', selected);
      btnFavorite.classList.toggle('text-rose-300', selected);
      const icon = btnFavorite.querySelector('svg');
      if (icon) icon.setAttribute('fill', selected ? 'currentColor' : 'none');
      const label = btnFavorite.querySelector<HTMLElement>('[data-favorite-label]');
      if (label) label.textContent = selected ? btnFavorite.dataset.labelSelected || '' : btnFavorite.dataset.labelDefault || '';
    };
    paintFavorite();
    btnFavorite?.addEventListener('click', () => {
      if (!gameId) return;
      const favorites = readFavorites();
      const selected = favorites.includes(gameId);
      localStorage.setItem('ag-favorites', JSON.stringify(selected ? favorites.filter((id) => id !== gameId) : [...favorites, gameId]));
      paintFavorite();
      window.dispatchEvent(new CustomEvent('ag:favorites-changed'));
    });

    try {
      // プレイするゲームモジュールのみを動的にインポート（Lazy Loading）
      const gameModule = await import(`../../games/${gameId}/index.ts`);
      
      // ローダーを非表示、キャンバスを表示
      if (loader) loader.style.opacity = '0';
      setTimeout(() => { if (loader) loader.style.display = 'none'; }, 300);
      canvas.classList.remove('hidden');

      // 操作説明を注入
      if (instructionBox) {
        const controls = lang === 'en' && controlsEn.length > 0 ? controlsEn : (gameModule.controls || []);
        instructionBox.innerHTML = controls.map((item: string) => `
          <div class="flex items-start gap-2.5">
            <span class="text-brand-accent font-extrabold select-none">•</span>
            <span class="font-medium text-slate-300 text-sm leading-relaxed">${item}</span>
          </div>
        `).join('');
      }

      // ゲーム側へ言語設定を伝える
      canvas.dataset.lang = lang;
      const gameTitle = document.querySelector<HTMLElement>('h1')?.textContent?.trim() || 'Mini Game';
      const markGameCleared = () => {
        if (!gameId) return;
        try {
          const cleared = JSON.parse(localStorage.getItem('ag-cleared-games') || '[]') as string[];
          if (cleared.includes(gameId)) return;
          localStorage.setItem('ag-cleared-games', JSON.stringify([...cleared, gameId]));
          window.dispatchEvent(new CustomEvent('ag:game-cleared', { detail: { gameId } }));
        } catch {
          localStorage.setItem('ag-cleared-games', JSON.stringify([gameId]));
        }
      };
      const saveHighScore = (score: number) => {
        if (!gameId) return;
        try {
          const scores = JSON.parse(localStorage.getItem('ag-high-scores') || '{}') as Record<string, number>;
          if (score <= (scores[gameId] || 0)) return;
          scores[gameId] = score;
          localStorage.setItem('ag-high-scores', JSON.stringify(scores));
        } catch {
          localStorage.setItem('ag-high-scores', JSON.stringify({ [gameId]: score }));
        }
      };
      installCanvasTextI18n(canvas, lang, gameTitle, markGameCleared, clearScore, saveHighScore);

      // 以前のゲームインスタンスがあれば確実に破棄する（Vite HMRや多重読み込み対策）
      if ((window as any).__currentGameInstance) {
        try {
          (window as any).__currentGameInstance.destroy?.();
        } catch (e) {
          console.error('以前のゲームインスタンスのクリーンアップに失敗しました:', e);
        }
      }

      // ゲームインスタンス初期化
      if (gameModule.init) {
        gameInstance = gameModule.init(canvas);
        (window as any).__currentGameInstance = gameInstance;
      }

      // リスタート制御
      if (btnRestart && gameInstance && typeof gameInstance.restart === 'function') {
        btnRestart.addEventListener('click', () => {
          gameInstance.restart();
          canvas.focus();
        });
      }

      // フルスクリーン制御
      if (btnFullscreen) {
        btnFullscreen.addEventListener('click', () => {
          if (!document.fullscreenElement) {
            container.requestFullscreen().catch(err => {
              console.error(`フルスクリーンエラー: ${err.message}`);
            });
          } else {
            document.exitFullscreen();
          }
        });
      }
    } catch (error) {
      console.error('ゲームの動的ロードに失敗しました:', error);
      if (loader) {
        const errTitle = lang === 'en' ? 'An error occurred' : 'エラーが発生しました';
        const errMsg = lang === 'en' ? 'Failed to load the game.' : 'ゲームの読み込みに失敗しました。';
        loader.innerHTML = `
          <div class="text-rose-500 font-bold mb-2">${errTitle}</div>
          <p class="text-xs text-slate-500">${errMsg}</p>
        `;
      }
    }
  }

  document.addEventListener('DOMContentLoaded', initGameContainer);
  document.addEventListener('astro:page-load', initGameContainer);

  // ページ遷移前に確実にクリーンアップを実行
  document.addEventListener('astro:before-swap', () => {
    if ((window as any).__currentGameInstance) {
      try {
        (window as any).__currentGameInstance.destroy?.();
      } catch (e) {
        console.error('ページ遷移前のクリーンアップに失敗しました:', e);
      }
      (window as any).__currentGameInstance = null;
    }
  });
</script>
