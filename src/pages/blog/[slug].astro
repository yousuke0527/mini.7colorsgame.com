---
import Layout from '../../layouts/Layout.astro';
import AdSense from '../../components/AdSense.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// 関連記事（同じカテゴリの他の記事）の取得
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 3);

const title = `${post.data.title} - Antigravity Games`;
const description = post.data.description;

// BlogPosting および BreadcrumbList 構造化データの動的生成
const canonicalUrl = `https://mini.7colorsgame.com/blog/${post.slug}/`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "@id": `${canonicalUrl}#blogposting`,
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.pubDate,
      "author": {
        "@type": "Person",
        "name": post.data.author
      },
      "publisher": {
        "@type": "Organization",
        "name": "Antigravity Games",
        "logo": {
          "@type": "ImageObject",
          "url": "https://mini.7colorsgame.com/favicon.svg"
        }
      },
      "mainEntityOfPage": canonicalUrl
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "ホーム",
          "item": "https://mini.7colorsgame.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "ブログ",
          "item": "https://mini.7colorsgame.com/blog/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": post.data.title,
          "item": canonicalUrl
        }
      ]
    }
  ]
};
---

<Layout title={title} description={description} jsonLd={JSON.stringify(jsonLd)}>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- パンくずナビゲーション -->
    <nav class="flex text-xs font-semibold text-slate-500 mb-8 items-center gap-2 overflow-x-auto whitespace-nowrap py-1">
      <a href="/" class="hover:text-purple-400 transition-colors">ホーム</a>
      <span>/</span>
      <a href="/blog/" class="hover:text-purple-400 transition-colors">ブログ</a>
      <span>/</span>
      <span class="text-slate-300 truncate">{post.data.title}</span>
    </nav>

    <!-- 記事ヘッダー -->
    <header class="mb-10 text-left relative">
      <span class="inline-block px-3 py-1 bg-purple-950/50 border border-purple-800/30 text-purple-400 text-xs font-semibold rounded-full mb-4">
        {post.data.category}
      </span>
      <h1 class="text-3xl sm:text-4xl font-bold font-display text-slate-100 mb-6 leading-tight tracking-tight">
        {post.data.title}
      </h1>

      <div class="flex items-center gap-4 text-xs text-slate-400 pt-2 border-b border-slate-800/50 pb-6">
        <!-- 著者 -->
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-purple-500 to-pink-500 p-[1.5px]">
            <div class="w-full h-full rounded-full bg-slate-950 flex items-center justify-center font-bold text-slate-200">
              {post.data.author.substring(0, 2)}
            </div>
          </div>
          <div>
            <span class="block text-slate-200 font-bold">{post.data.author}</span>
            <span class="text-[10px] text-slate-500">ゲームUXスペシャリスト</span>
          </div>
        </div>

        <div class="h-6 w-[1px] bg-slate-800"></div>

        <!-- 日付 -->
        <div>
          <span class="block text-slate-500">公開日</span>
          <time datetime={post.data.pubDate} class="font-medium text-slate-300">
            {new Date(post.data.pubDate).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
      </div>
    </header>

    <!-- 記事本文 -->
    <article class="prose prose-invert prose-purple max-w-none prose-headings:font-display prose-headings:font-bold prose-a:text-purple-400 hover:prose-a:text-pink-400 prose-blockquote:border-purple-500 prose-blockquote:bg-slate-950/40 prose-blockquote:p-4 prose-blockquote:rounded-r-lg">
      <div class="bg-slate-900/40 border border-slate-800/80 rounded-2xl p-6 mb-8">
        <h2 class="text-lg font-bold text-purple-400 mt-0 mb-3 flex items-center gap-2">
          💡 この記事の要点（1秒結論）
        </h2>
        <p class="text-sm text-slate-300 leading-relaxed mb-0">
          {post.data.description}
        </p>
      </div>

      <Content />
    </article>

    <!-- タグ -->
    <div class="mt-8 pt-6 border-t border-slate-800/50 flex flex-wrap gap-2">
      {post.data.tags.map(tag => (
        <span class="px-2.5 py-1 bg-slate-850 border border-slate-800 text-slate-400 text-xs rounded-lg font-medium">
          #{tag}
        </span>
      ))}
    </div>

    <!-- 著者詳細 (E-E-A-T) -->
    <div class="mt-12 p-6 bg-slate-900/60 backdrop-blur-md border border-slate-800/80 rounded-2xl flex flex-col sm:flex-row gap-4 items-start shadow-lg">
      <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-purple-500 to-pink-500 p-[2px] shrink-0">
        <div class="w-full h-full rounded-full bg-slate-950 flex items-center justify-center font-bold text-slate-100 text-lg">
          {post.data.author.substring(0, 2)}
        </div>
      </div>
      <div>
        <h4 class="text-sm font-bold text-slate-200 mb-1">著者プロフィール：{post.data.author}</h4>
        <p class="text-xs text-slate-400 leading-relaxed">
          当サイトの専属コラムニスト。ブラウザゲームのアルゴリズム解析、ユーザー体験設計、およびゲームプレイを通じた認知科学を専門としています。プレイヤーの皆様に最高に有用で信頼できる情報をお届けします。
        </p>
      </div>
    </div>

    <!-- 中間広告 (CLS回避) -->
    <div class="my-12">
      <span class="text-[10px] font-semibold tracking-wider text-slate-500 block mb-2 text-center">SPONSORED LINK</span>
      <AdSense slot="1005373448" />
    </div>

    <!-- 関連記事 -->
    {relatedPosts.length > 0 && (
      <div class="mt-16 pt-8 border-t border-slate-850">
        <h3 class="text-xl font-bold font-display text-slate-200 mb-6">
          こちらの記事もおすすめ
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map(p => (
            <a href={`/blog/${p.slug}/`} class="group block p-5 bg-slate-900/40 border border-slate-800 hover:border-purple-500/50 rounded-xl transition-all duration-200">
              <span class="text-[10px] text-purple-400 font-bold block mb-2 uppercase">{p.data.category}</span>
              <h4 class="text-sm font-bold text-slate-300 group-hover:text-purple-400 transition-colors line-clamp-2 mb-2">
                {p.data.title}
              </h4>
              <p class="text-xs text-slate-400 line-clamp-2 leading-relaxed">
                {p.data.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    )}
  </main>
</Layout>
