---
import Layout from '../../layouts/Layout.astro';
import AdSense from '../../components/AdSense.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
// 公開日順にソート
const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const categories = [...new Set(posts.map(post => post.data.category))];

const title = 'ゲーム攻略コラム＆脳トレ科学ブログ - Antigravity Games';
const description = 'ブラウザゲームのプロが解説する攻略テクニックや必勝法、脳科学に基づいた脳トレゲームの効果などを分かりやすく紹介するお役立ちコラム集です。';

// BreadcrumbListの構造化データ
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "ホーム",
      "item": "https://mini.7colorsgame.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "ブログ",
      "item": "https://mini.7colorsgame.com/blog/"
    }
  ]
};
---

<Layout title={title} description={description} jsonLd={JSON.stringify(breadcrumbLd)}>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- ヒーローセクション -->
    <div class="text-center mb-16 relative">
      <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-48 h-48 bg-purple-500/10 rounded-full blur-3xl -z-10"></div>
      <h1 class="text-4xl sm:text-5xl font-bold font-display text-transparent bg-clip-text bg-gradient-to-r from-purple-400 via-pink-500 to-red-500 mb-4 tracking-tight">
        GAME TIPS & COLUMNS
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        プロが明かす攻略必勝法から、脳を鍛えるパズルゲームの科学的効果まで、ゲームライフを豊かにする「人々第一(People-First)」の良質な知識をお届けします。
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- メインコンテンツ (記事一覧) -->
      <div class="lg:col-span-3 space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sortedPosts.map(post => (
            <article class="group relative bg-slate-900/60 backdrop-blur-md border border-slate-800/80 rounded-2xl overflow-hidden hover:border-purple-500/50 transition-all duration-300 flex flex-col h-full shadow-lg shadow-purple-950/5">
              <div class="p-6 flex flex-col flex-grow">
                <!-- カテゴリ ＆ 日付 -->
                <div class="flex items-center justify-between gap-4 mb-4 text-xs font-semibold text-slate-400">
                  <span class="px-2.5 py-1 bg-purple-950/50 border border-purple-800/30 text-purple-400 rounded-full">
                    {post.data.category}
                  </span>
                  <time datetime={post.data.pubDate}>
                    {new Date(post.data.pubDate).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>

                <!-- タイトル -->
                <h2 class="text-xl font-bold font-display text-slate-200 group-hover:text-purple-400 transition-colors duration-200 line-clamp-2 mb-3">
                  <a href={`/blog/${post.slug}/`}>
                    {post.data.title}
                  </a>
                </h2>

                <!-- 説明文 -->
                <p class="text-slate-400 text-sm line-clamp-3 mb-6 flex-grow leading-relaxed">
                  {post.data.description}
                </p>

                <!-- 著者 ＆ 続きを読む -->
                <div class="flex items-center justify-between pt-4 border-t border-slate-800/50 mt-auto">
                  <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-full bg-gradient-to-tr from-purple-500 to-pink-500 p-[1.5px]">
                      <div class="w-full h-full rounded-full bg-slate-950 flex items-center justify-center text-[10px] font-bold text-slate-300">
                        {post.data.author.substring(0, 2)}
                      </div>
                    </div>
                    <span class="text-xs text-slate-300 font-medium">{post.data.author}</span>
                  </div>
                  <a href={`/blog/${post.slug}/`} class="text-xs font-bold text-purple-400 group-hover:text-pink-400 transition-colors flex items-center gap-1">
                    記事を読む <span>→</span>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- サイドバー -->
      <aside class="lg:col-span-1 space-y-8">
        <!-- 広告セクション (CLS回避) -->
        <div class="bg-slate-900/40 border border-slate-800/80 rounded-2xl p-4">
          <span class="text-[10px] font-semibold tracking-wider text-slate-500 block mb-2 text-center">SPONSORED LINK</span>
          <AdSense slot="1005373448" />
        </div>

        <!-- カテゴリリスト -->
        <div class="bg-slate-900/60 backdrop-blur-md border border-slate-800/80 rounded-2xl p-6">
          <h3 class="text-lg font-bold font-display text-slate-200 mb-4 border-b border-slate-800 pb-2">
            カテゴリー
          </h3>
          <ul class="space-y-2">
            {categories.map(cat => (
              <li>
                <span class="block px-3 py-2 text-sm text-slate-400 hover:text-purple-400 hover:bg-purple-950/20 rounded-lg transition-colors cursor-pointer font-medium">
                  {cat}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- プラットフォームの信頼性 (E-E-A-Tの担保) -->
        <div class="bg-slate-900/60 backdrop-blur-md border border-slate-800/80 rounded-2xl p-6 text-sm text-slate-400 leading-relaxed">
          <h3 class="text-md font-bold font-display text-slate-200 mb-3">
            編集ポリシー
          </h3>
          <p class="text-xs mb-3">
            当サイトのコンテンツは、ゲーム開発者、UXデザイナー、教育科学の知見を持つ専門チームによって執筆・監修されています。
          </p>
          <p class="text-xs">
            プレイヤーの皆様に最高品質で「本当に役立つ」オリジナルの実践テクニックを提供することを約束します。
          </p>
        </div>
      </aside>
    </div>
  </main>
</Layout>
